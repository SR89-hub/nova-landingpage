<!DOCTYPE html>
<html>

<head>
    <style>
        body {
            font-family: 'Poppins', Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            margin: 0;
            padding: 0;
            background-color: #f4f4f4;
        }

        .container {
            max-width: 600px;
            margin: 30px auto;
            border: 1px solid #e0e0e0;
            border-radius: 12px;
            overflow: hidden;
            background-color: #ffffff;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
        }

        .header {
            background: #0A0A0A;
            border-bottom: 4px solid #6BC4BC;
            padding: 25px;
            text-align: center;
            color: white;
        }

        .form-title {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .content {
            padding: 35px;
            background-color: #ffffff;
        }

        .field {
            margin-bottom: 22px;
        }

        .label {
            font-weight: 700;
            color: #5BAFA8;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 4px;
            display: block;
        }

        .value {
            font-size: 16px;
            color: #1a1a1a;
            padding: 4px 0;
            line-height: 1.4;
            border-bottom: 1px solid #f2f2f2;
        }

        .message-box {
            background-color: #fbfcfc;
            border: 1px solid #edf2f2;
            border-radius: 8px;
            padding: 15px;
            margin-top: 8px;
            min-height: 100px;
            white-space: pre-wrap;
            font-size: 15px;
        }

        .footer {
            background-color: #fcfcfc;
            padding: 18px;
            text-align: center;
            font-size: 11px;
            color: #aaa;
            border-top: 1px solid #f0f0f0;
        }

        /* This class ensures the variables are hidden from view */
        .hidden-vars {
            display: none !important;
            visibility: hidden;
            opacity: 0;
            font-size: 0;
        }
    </style>
</head>

<body>

    <div class="container">
        <div class="header">
            <h2 class="form-title">Nova leads</h2>
        </div>

        <div class="content">
            <div class="field">
                <span class="label">Full Name</span>
                <div class="value">{{$json.fullName}}</div>
            </div>

            <div class="field">
                <span class="label">Company</span>
                <div class="value">{{$json.company}}</div>
            </div>

            <div class="field">
                <span class="label">Email Address</span>
                <div class="value">{{$json.email}}</div>
            </div>

            <div class="field">
                <span class="label">Phone Number</span>
                <div class="value">{{$json.phone}}</div>
            </div>

            <div class="field" style="margin-top: 30px;">
                <span class="label">Message</span>
                <div class="message-box">{{$json.message}}</div>
            </div>
        </div>
    </div>

</body>

</html>