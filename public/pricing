<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    /* Reset & Base Styles */
    body {
      margin: 0;
      padding: 0;
      width: 100% !important;
      -webkit-text-size-adjust: 100%;
      -ms-text-size-adjust: 100%;
      background-color: #f8fafc;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      color: #1e293b;
    }

    .wrapper {
      width: 100%;
      table-layout: fixed;
      background-color: #f8fafc;
      padding-bottom: 40px;
    }

    .main-container {
      max-width: 600px;
      margin: 40px auto;
      background-color: #ffffff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
      border: 1px solid #e2e8f0;
    }

    /* Header Section */
    .header {
      background-color: #0f172a;
      padding: 40px 30px;
      text-align: center;
    }

    .header h1 {
      margin: 0;
      color: #ffffff;
      font-size: 24px;
      font-weight: 700;
      letter-spacing: -0.025em;
    }

    .status-badge {
      display: inline-block;
      margin-top: 12px;
      background-color: #14b8a6;
      color: #ffffff;
      padding: 6px 16px;
      border-radius: 9999px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* Body Content */
    .content {
      padding: 40px 30px;
    }

    .section-title {
      font-size: 13px;
      font-weight: 700;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 20px;
      display: block;
      border-bottom: 1px solid #f1f5f9;
      padding-bottom: 8px;
    }

    /* List Layout (One by One) */
    .info-list {
      margin-bottom: 32px;
    }

    .info-item {
      display: flex;
      flex-direction: column;
      padding: 12px 0;
      border-bottom: 1px solid #f8fafc;
    }

    .info-item:last-child {
      border-bottom: none;
    }

    .info-label {
      font-size: 11px;
      color: #94a3b8;
      font-weight: 600;
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 8px;
      text-transform: uppercase;
      letter-spacing: 0.025em;
    }

    .info-value {
      font-size: 16px;
      color: #334155;
      font-weight: 500;
      padding-left: 22px;
      /* Align with text after icon */
    }

    /* Message Box */
    .message-container {
      background-color: #fdfdfd;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      padding: 24px;
      position: relative;
      margin-top: 10px;
    }

    .message-text {
      font-size: 15px;
      line-height: 1.6;
      color: #475569;
      margin: 0;
      font-style: italic;
    }

    .quote-icon {
      position: absolute;
      top: -12px;
      left: 20px;
      background: white;
      padding: 0 8px;
      color: #14b8a6;
    }

    /* Footer Metadata */
    .footer {
      background-color: #f8fafc;
      padding: 24px 30px;
      border-top: 1px solid #e2e8f0;
      text-align: center;
    }

    .meta-table {
      width: 100%;
      font-size: 12px;
      color: #94a3b8;
    }

    .meta-tag {
      display: inline-block;
      padding: 4px 10px;
      background: #f1f5f9;
      border-radius: 6px;
      margin: 4px;
    }

    /* SVG Icons */
    .icon {
      width: 14px;
      height: 14px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
  </style>
</head>

<body>
  <div class="wrapper">
    <div class="main-container">
      <!-- Dynamic Header based on form type -->
      <div class="header">
        <h1>{{$json.form_type || 'NOVA leads '}}</h1>
        <div class="status-badge">{{$json.plan}}</div>
      </div>

      <!-- Main Content -->
      <div class="content">
        <span class="section-title">Submission Details</span>

        <div class="info-list">
          <div class="info-item">
            <span class="info-label">
              <svg class="icon" viewBox="0 0 24 24">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
              Customer Name
            </span>
            <span class="info-value">{{$json.name}}</span>
          </div>

          <div class="info-item">
            <span class="info-label">
              <svg class="icon" viewBox="0 0 24 24">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
              </svg>
              Request Category
            </span>
            <span class="info-value" style="color: #14b8a6; font-weight: 700;">{{$json.form_type || 'General
              Inquiry'}}</span>
          </div>

          <div class="info-item">
            <span class="info-label">
              <svg class="icon" viewBox="0 0 24 24">
                <path d="M3 21l2-2m0 0V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v14m-14 0h14"></path>
              </svg>
              Company
            </span>
            <span class="info-value">{{$json.company || 'Not Specified'}}</span>
          </div>

          <div class="info-item">
            <span class="info-label">
              <svg class="icon" viewBox="0 0 24 24">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
              Contact Email
            </span>
            <span class="info-value">{{$json.email}}</span>
          </div>

          <div class="info-item">
            <span class="info-label">
              <svg class="icon" viewBox="0 0 24 24">
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z">
                </path>
              </svg>
              Phone Number
            </span>
            <span class="info-value">{{$json.phone}}</span>
          </div>
        </div>

        <span class="section-title">Requirements & Message</span>
        <div class="message-container">
          <div class="quote-icon">
            <svg class="icon" viewBox="0 0 24 24" style="width: 24px; height: 24px;">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
          </div>
          <p class="message-text">
            {{$json.message || 'No additional requirements or notes were provided.'}}
          </p>
        </div>
      </div>

    </div>
  </div>
</body>

</html>